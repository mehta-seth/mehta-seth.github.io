---
// src/layouts/EssayLayout.astro
//
// Dario-style essay page (§3.2 of the v1 plan).
//
// Page chrome:
//   - Top-left:  small wordmark (home link).
//   - Top-right: "Archive" link (points at / for v1) — ThemeToggle is
//                fixed-positioned by global.css and floats above this.
//   - Body:      centered ~42.5rem column (max-w-essay).
//   - Sidebar:   sticky ToC on left at ≥1024px, ONLY WHEN the essay has
//                H2 headings to populate it. Hidden on mobile, and
//                entirely absent (grid collapses to a single column)
//                when the essay has no H2s.
//   - Footer:    "Back to top" link.
//
// Notes on structure:
//   - When `hasToc` is true, the layout uses a 3-column grid (left
//     margin / essay column / right margin). The ToC sits in the LEFT
//     margin column, not pushing the essay rightward. This is the key
//     Dario-layout trick.
//   - When `hasToc` is false (essay has no H2s — the case for the
//     "Four Shopkeepers" essay), the layout uses a single centered
//     column. No empty grid columns, no ToC affordances. The essay
//     centers cleanly in the viewport.
//   - id="top" on the page header is the target for the back-to-top
//     anchor at the bottom.
//   - Body typography for MDX-rendered HTML lives in the
//     <style is:global> block at the bottom — scoped styles don't
//     reach into MDX output.

import BaseLayout from './BaseLayout.astro';
import Wordmark from '@/components/Wordmark.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  headings: MarkdownHeading[];
}

const { title, subtitle, date, headings } = Astro.props;

// Only render the ToC chrome (the aside, the grid 3-column shape) when
// there's actually a ToC to populate. The TableOfContents component
// already returns null when there are no H2s — but the layout's
// grid-template-columns and the .essay-toc-wrap aside still occupied
// space, leaving the essay column visually offset to the right of
// viewport center on essays with no headings. Computing `hasToc` here
// and gating both the grid and the aside on it fixes that cleanly.
const hasToc = headings.some((h) => h.depth === 2);

// Date format: "April 2026" — month + year, matching Dario's pattern.
// en-GB locale chosen for consistency with the rest of the site (LSE /
// British conventions); for month/year-only it doesn't actually matter.
const formattedDate = date.toLocaleDateString('en-GB', {
  month: 'long',
  year: 'numeric',
});
const isoDate = date.toISOString();

// Browser-tab title. The wordmark's full bilingual string is too long
// here; "{Essay Title} — Adit Mehta" matches Phase 5's SEO spec (§6).
const headTitle = `${title} — Adit Mehta`;

// SEO description for the essay page. Prefers subtitle (the author's
// own one-line summary) when present; falls back to title. Always
// suffixed with an author tag so the description is substantive even
// when the subtitle is very short (Phase 5 §5.3 target: 140–160 chars).
// If this ever lands above the ~160 char limit for a given essay's
// long subtitle, feed readers and search engines truncate it
// gracefully — we're not chasing perfection here, just ensuring the
// snippet is useful.
const headDescription = subtitle
  ? `${subtitle}. An essay by Adit Mehta.`
  : `${title}. An essay by Adit Mehta.`;
---

<BaseLayout title={headTitle} description={headDescription} ogType="article">
  <ThemeToggle />

  {/* Page header — wordmark only. The fixed theme toggle floats over
      the right side from global.css; the header has enough right
      padding to keep the wordmark clear of it on narrow viewports.
      The Archive link was removed in April 2026: with only one essay
      shipped and the home page already serving as the index, the link
      had nowhere meaningful to point. Reintroduce when /essays/
      becomes a real archive page. */}
  <header class="essay-header" id="top">
    <Wordmark href="/" size="small" />
  </header>

  {/* Apply a class on the wrapper that toggles between single-column
      (no ToC) and three-column-grid (with ToC) layouts. CSS does the
      rest. */}
  <div class:list={['essay-grid', hasToc && 'essay-grid--has-toc']}>
    {hasToc && (
      <aside class="essay-toc-wrap" aria-label="Table of contents">
        <TableOfContents headings={headings} />
      </aside>
    )}

    <article class="essay">
      <header class="essay__head">
        <h1 class="essay__title">{title}</h1>
        {subtitle && <p class="essay__subtitle">{subtitle}</p>}
        <p class="essay__date">
          <time datetime={isoDate}>{formattedDate}</time>
        </p>
      </header>

      {/* The MDX body is rendered into here via <slot />. All in-body
          typography (paragraph rhythm, headings, blockquote, lists,
          images, footnotes) is styled in the <style is:global> block
          below — scoped styles don't reach into MDX-rendered HTML. */}
      <div class="essay__body">
        <slot />
      </div>

      <footer class="essay__foot">
        <a href="#top" class="essay__backtotop">↑ Back to top</a>
      </footer>
    </article>
  </div>
</BaseLayout>

<style>
  /* ─── Page header ─────────────────────────────────────────────────
     Just the wordmark, sitting left. padding-right leaves room for the
     fixed theme toggle (top:1.25rem, right:1.25rem, ~2.5rem wide) so
     the toggle never visually crashes into the wordmark on narrow
     viewports. (The Archive link that used to sit on the right was
     removed in April 2026 — see header comment.) */
  .essay-header {
    display: flex;
    align-items: baseline;
    padding: 2rem 1.5rem 0;
    padding-right: 4.5rem;
    max-width: 80rem;
    margin-inline: auto;
  }

  /* ─── Layout shell ────────────────────────────────────────────────
     Default (mobile, AND any essay regardless of ToC presence):
     single column, essay full-width within padding.
     Desktop with ToC (≥1024px AND .essay-grid--has-toc): three columns
     (1fr | essay | 1fr). ToC slots into column 1, right column stays
     empty for symmetry — keeping the essay column perfectly centered
     in the viewport.
     Desktop without ToC: stays single-column — essay centers in the
     viewport on its own max-width without grid scaffolding. */
  .essay-grid {
    display: block;
    max-width: 42.5rem;
    margin-inline: auto;
    padding: 3rem 1.5rem 6rem;
  }

  .essay-toc-wrap {
    /* Hidden on mobile per §3.2: "Hide on mobile". (When .essay-grid
       --has-toc is absent, the aside isn't rendered at all, so this
       rule matters only when there IS a ToC and we're below 1024px.) */
    display: none;
  }

  @media (min-width: 1024px) {
    /* The 3-column grid only applies when the layout has been told
       there's a ToC to host. Without --has-toc, the desktop shape
       stays single-column with a wider top padding for breathing room. */
    .essay-grid--has-toc {
      display: grid;
      grid-template-columns:
        minmax(0, 1fr)
        minmax(auto, 42.5rem)
        minmax(0, 1fr);
      max-width: 80rem;
      column-gap: 0;
      padding: 6rem 2rem 8rem;
    }
    .essay-grid--has-toc .essay-toc-wrap {
      display: block;
      grid-column: 1;
      justify-self: end;
      width: 14rem;
      margin-right: 3rem;
      /* Sticky positioning per §3.2. The top offset matches the page
         header's vertical reach so the ToC sits comfortably below it
         once the user scrolls. */
      position: sticky;
      top: 6rem;
      align-self: start;
      /* Cap height for very long ToCs so it scrolls internally rather
         than bleeding off the bottom of the viewport. */
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
    }
    .essay-grid--has-toc .essay {
      grid-column: 2;
    }
    /* No-ToC desktop: keep the column centered, just give it a touch
       more vertical breathing room than the mobile padding. */
    .essay-grid:not(.essay-grid--has-toc) {
      padding: 6rem 2rem 8rem;
    }
  }

  /* ─── Essay article frame (scoped) ───────────────────────────────
     Only the wrapper itself + its direct head/foot chrome live here.
     The body content typography is in the <style is:global> block
     below because scoped styles don't reach into MDX-rendered HTML. */
  .essay {
    width: 100%;
    max-width: 42.5rem;
  }

  .essay__head {
    margin-bottom: 3rem;
  }
  .essay__title {
    font-size: var(--fs-h1);
    font-weight: 600;
    letter-spacing: -0.015em;
    /* Tighter line-height than the base heading value — at 40→56px,
       var(--lh-heading) of 1.2 leaves gulfs of space between wrapped
       lines. 1.1 reads as a single tight title block, which is what
       a title wants to be. */
    line-height: 1.1;
    /* Bumped from 0.5rem to 0.75rem — at the new 40→56 title size the
       subtitle needed slightly more air, otherwise it felt glued to
       the last line of the title. */
    margin-bottom: 0.75rem;
  }
  .essay__subtitle {
    font-style: italic;
    /* Bumped from 1.125rem (18px) to 1.25rem (20px) — sits comfortably
       between the large title (40→56) and body (20→22), reading as a
       deliberate second register rather than an afterthought. */
    font-size: 1.25rem;
    color: var(--text-muted);
    margin: 0 0 1rem 0;
    line-height: 1.4;
  }
  .essay__date {
    font-size: var(--fs-small);
    color: var(--text-muted);
    margin: 0;
  }

  .essay__foot {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .essay__backtotop {
    font-size: var(--fs-small);
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .essay__backtotop:hover,
  .essay__backtotop:focus-visible {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
</style>

<style is:global>
  /* ─── Essay body typography (global because MDX-rendered) ────────
     Scoped styles in this file don't reach into <Content />'s output;
     it's compiled into a separate component with its own scope. We
     use is:global and namespace by .essay__body to avoid polluting
     the home page or other layouts.

     The values here implement §3.2's "Body type: serif, ~19–20px,
     generous line-height (~1.65), paragraph spacing that's noticeably
     bigger than line-height" and §3.4's type scale. The goal is that
     a paragraph rendered here, side-by-side with one from
     darioamodei.com/essay/machines-of-loving-grace, reads at
     equivalent comfort. */

  .essay__body {
    /* Slightly larger than the site default — Dario's essays measure
       ~19–20px, and the body var already targets that range. The
       column max-width of 42.5rem (~680px) hits the canonical 60–75
       characters per line at this font size. */
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }

  /* Paragraphs: vertical rhythm wider than line-height so each block
     reads as a discrete unit, not a continuation. ~1.4em ≈ 1.6 lines,
     which sits clearly between two paragraphs without feeling sparse. */
  .essay__body p {
    margin: 0 0 1.4em 0;
  }

  /* Headings inside the body need their own rhythm. H2s are chapter
     breaks — a lot of air above so the reader notices the shift; H3s
     are subdivisions, less dramatic. */
  .essay__body h2 {
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2.75em 0 0.6em;
    line-height: 1.25;
  }
  .essay__body h3 {
    font-size: var(--fs-h3);
    font-weight: 600;
    margin: 2em 0 0.5em;
    line-height: 1.3;
  }

  /* rehype-autolink-headings (behavior: 'wrap') wraps each heading's
     text in <a class="heading-anchor" href="#slug">. Without this rule
     they'd inherit the global accent-color underlined link styling and
     every heading would look like an underlined link. Make them look
     like normal heading text, with a subtle color shift on hover as
     the only signal that they're linkable. */
  .essay__body .heading-anchor {
    color: inherit;
    text-decoration: none;
  }
  .essay__body .heading-anchor:hover {
    color: var(--accent);
  }

  /* Section break — generous vertical air between movements without a
     visible rule. Authors signal a break in the MDX with the standard
     `---` (which renders as <hr>); we hide the rule itself and convert
     it into pure breathing room. The 3.5em / 3em values are deliberately
     larger than a paragraph break (1.4em) so the eye registers a
     genuine pause, not just another paragraph.

     If a future essay wants a VISIBLE ornament (`* * *`, dot leaders,
     etc.), it can be added by introducing a class on the hr or by
     authoring an explicit ornament in the MDX. v1 prefers the quietest
     option. */
  .essay__body hr {
    border: 0;
    height: 0;
    margin: 3.5em 0 3em;
    /* Belt-and-braces: kill any UA default outline/border that might
       slip through across browsers. */
    background: transparent;
  }

  /* Blockquote — left bar in the warm border color, italic body, a bit
     of left padding. Distinct enough to read as a quote at a glance,
     not so dramatic that pull-quotes shout. */
  .essay__body blockquote {
    margin: 1.8em 0;
    padding: 0.2em 0 0.2em 1.4em;
    border-left: 2px solid var(--border);
    font-style: italic;
    color: var(--text-muted);
  }
  .essay__body blockquote p:last-child {
    margin-bottom: 0;
  }

  /* Lists: keep markers in the gutter (default) and the same line-
     height as paragraphs so a bulleted item and a paragraph read as
     siblings, not as different rhythmic units. */
  .essay__body ul,
  .essay__body ol {
    margin: 0 0 1.4em 0;
    padding-left: 1.4em;
  }
  .essay__body li {
    margin-bottom: 0.4em;
  }
  .essay__body li > p {
    /* When MDX wraps a list item's content in a <p> (it sometimes does
       for multi-line items), the default 1.4em margin throws off
       spacing. Reset it inside list items. */
    margin: 0 0 0.4em 0;
  }
  .essay__body ol > li::marker,
  .essay__body ul > li::marker {
    color: var(--text-muted);
  }

  /* Inline code: distinct background pill, slightly smaller than body,
     mono font. Code BLOCKS are deferred per the spec (§3.2 v1 supports
     only inline code); when added later, a separate `pre` rule goes
     here. */
  .essay__body :not(pre) > code {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.88em;
    padding: 0.1em 0.35em;
    background-color: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text);
  }

  /* Bare images (markdown `![alt](path)` syntax). For most in-essay
     photographs, use the <Figure> component instead — it handles
     responsive variants (AVIF/WebP/JPEG at 5 widths), captions, and
     the wide/full size variants. This rule remains as a sensible
     default for any plain <img> that ends up in the essay body
     (icons, screenshots, etc.). */
  .essay__body img {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 2.4em auto;
    border-radius: 2px;
  }

  /* ─── In-essay figures (Figure.astro) ────────────────────────────
     Three size variants:
       column = default. Fits inside the 42.5rem essay column.
       wide   = breaks past the column at ≥1280px. On smaller
                viewports it behaves like column.
       full   = edge-to-edge of the viewport. Caption stays
                column-width for readability.

     Tall-aspect handling: max-height: 80vh on the image keeps a
     portrait-orientation photograph from dominating the page. The
     image is still visible without the user having to scroll past
     it to find more text. object-fit: contain preserves the
     aspect ratio inside the constrained box.

     The figure block itself uses the same vertical rhythm as a
     paragraph break (1.4em) plus a touch more (2.4em total) so
     figures read as visual pauses, not as continuations of prose.
  */

  .essay__body .figure {
    margin: 2.4em auto;
  }

  .essay__body .figure__img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 2px;
    margin: 0 auto;
  }

  /* Caption — muted serif, italic, body-small size, generous top
     margin so it's clearly under-the-photo and not crashing into
     it. Stays column-width even when the image goes wide/full,
     so the prose-and-caption rhythm is consistent across sizes. */
  .essay__body .figure__caption {
    font-family: 'Newsreader', 'Charter', 'Georgia', serif;
    font-size: var(--fs-small);
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0.9em auto 0;
    max-width: 42.5rem;
    text-align: left;
  }

  /* Caption inline emphasis (the * * markdown markers) — flip to
     roman so emphasised words read as MORE emphatic against the
     surrounding italic, not less. Standard typographic convention
     for italic-set captions. */
  .essay__body .figure__caption em {
    font-style: normal;
  }

  /* Column = the default. No size-specific rules needed; the figure
     and image fill 100% of the essay column (42.5rem). */

  /* Wide — breaks out past the essay column on ≥1280px viewports.
     The breakout is symmetric (negative margin on both sides) so
     the figure stays centered within the column. Below 1280px, no
     breakout — the image stays at column width. */
  @media (min-width: 1280px) {
    .essay__body .figure--wide {
      width: calc(100% + 12.5rem);
      margin-left: -6.25rem;
      margin-right: -6.25rem;
    }
  }

  /* Full — edge-to-edge of the viewport. The image goes full-bleed;
     the figcaption inside it stays column-width (its own rule above
     constrains it). The classic "50% - 50vw" trick gets the image
     out to the viewport edges from inside a centered column.
     border-radius: 0 because corner radius on a full-bleed photo
     looks wrong — it implies the photo is a card, not the moment. */
  .essay__body .figure--full .figure__img {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    border-radius: 0;
    /* Allow more height for full-bleed — the image IS the focus
       at this size. */
    max-height: 90vh;
  }

  /* ─── Footnote refs (inline) ─────────────────────────────────────
     The Footnote component renders <sup class="footnote-ref"> for the
     inline marker. Has to be global so the styles apply to elements
     rendered inside MDX content. */
  .essay__body .footnote-ref {
    /* line-height: 0 keeps the superscript from creating extra
       vertical space in the line. */
    line-height: 0;
    font-size: 0.7em;
    /* position: relative is the anchor for the absolutely-positioned
       .footnote-preview popover (see below). Required even when the
       preview isn't present — costs nothing, simplifies the rule. */
    position: relative;
  }
  .essay__body .footnote-ref a {
    text-decoration: none;
    color: var(--accent);
    padding: 0 0.15em;
    /* No `cursor: help` — the styled popover that appears on hover is
       its own strong visual signal that something is happening. The
       question-mark cursor read as fussy on top of that. The default
       browser link cursor (the hand) is what shows now, which matches
       every other anchor on the site. */
  }
  .essay__body .footnote-ref a:hover {
    text-decoration: underline;
    text-decoration-thickness: 0.05em;
    text-underline-offset: 0.15em;
  }

  /* ─── Footnote preview popover (Dario-style) ─────────────────────
     Hover the inline marker → a styled card surfaces with the
     footnote's content, set in body serif. Styled via plain CSS,
     positioned absolutely above the marker, hidden by default,
     shown on :hover and :focus-within. Zero JS.

     Positioning notes:
       - The popover is a child of the <sup>, which is position: relative.
       - bottom: calc(100% + ...) puts it above the marker. With the sup's
         line-height: 0, "100%" is effectively the cap-height of the
         marker glyph, so we add ~1.4em of clearance to lift the popover
         clear of the line below it.
       - Centered horizontally on the marker via left: 50% / translateX(-50%).
         If the marker is near the right edge of the viewport, the popover
         can clip — max-width: min(26rem, calc(100vw - 2rem)) prevents
         overflow on narrow viewports; viewport-edge cases on desktop
         are rare and acceptable for v1. (Anchor Positioning API would
         solve this cleanly but Safari/Firefox support is still partial.)

     Typography reset:
       The popover inherits .footnote-ref's font-size: 0.7em and
       line-height: 0 from its parent. Both are explicitly reset to
       body values so the popover content reads as ordinary prose, not
       superscripted text.

     Touch handling:
       @media (hover: none) hides the popover entirely on touch devices.
       Tapping the marker just navigates to the bottom-of-essay footnote,
       which is the right behavior on mobile. */
  .essay__body .footnote-preview {
    /* Hidden by default; shown on hover/focus. */
    position: absolute;
    bottom: calc(100% + 1.4em);
    left: 50%;
    transform: translateX(-50%);

    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 150ms ease, visibility 150ms ease;

    /* Sizing — wide enough to read comfortably, capped on mobile. */
    width: max-content;
    max-width: min(26rem, calc(100vw - 2rem));

    /* Reset inherited <sup> styling so the body reads as ordinary prose. */
    font-family: var(--font-serif);
    font-size: var(--fs-small);
    font-style: normal;
    font-weight: 400;
    vertical-align: baseline;
    line-height: 1.55;
    text-align: left;
    letter-spacing: 0;
    color: var(--text);

    /* Card styling — slightly elevated background, subtle border, soft
       shadow. Reads as a quiet card sitting on top of the page, not as
       a heavy modal. */
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.95rem 1.15rem;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);

    /* Stack above body content. ThemeToggle sits at z-index higher
       (it's fixed-positioned chrome); 50 keeps the popover above
       prose, blockquotes, and images without fighting site UI. */
    z-index: 50;
  }

  .essay__body .footnote-ref:hover .footnote-preview,
  .essay__body .footnote-ref:focus-within .footnote-preview {
    visibility: visible;
    opacity: 1;
  }

  /* The footnote number prefix inside the popover ("¹ The shop is …").
     Mirrors the visual format of the bottom-of-essay footnote items so
     hovering and reading-down feel like the same thing. */
  .essay__body .footnote-preview__num {
    display: inline;
    font-size: 0.72em;
    vertical-align: super;
    color: var(--text-muted);
    margin-right: 0.4em;
    font-weight: 500;
    /* Reset any inherited line-height from the popover so the
       superscript number doesn't shift the surrounding line. */
    line-height: 0;
  }

  /* Touch devices: hover doesn't apply meaningfully. Hide the popover
     entirely — tapping the marker should just navigate to the footnote
     item at the bottom of the essay. */
  @media (hover: none) {
    .essay__body .footnote-preview {
      display: none;
    }
  }

  /* ─── Asterism divider + Footnotes heading ───────────────────────
     Marks the transition from essay body to footnote apparatus. Both
     elements are rendered by <FootnoteSection /> in MDX. The label is
     a <p>, not an <h2>, deliberately — keeps it out of the rehype-slug
     heading tree and therefore out of the auto-generated ToC. Future
     essays with real body H2s will show a clean ToC of just those
     headings, with no "Footnotes" entry. */

  /* The asterism. ⁂ (U+2042) is the typographic standard for a
     stronger-than-paragraph section break. Centered, muted, with
     letter-spacing to give the glyph air. The vertical margins are
     larger than a normal paragraph break — this is the strongest
     visual break in the essay. */
  .essay__body .essay-asterism {
    text-align: center;
    color: var(--text-muted);
    font-size: 1.4em;
    line-height: 1;
    margin: 4em 0 2em;
    letter-spacing: 0.4em;
    /* Account for the letter-spacing pushing the glyph right of true
       center: pull back by half a unit. */
    text-indent: 0.4em;
    /* Disable any user selection — it's an ornament, not content. */
    user-select: none;
  }

  /* "Footnotes" label. Sized like a section heading but rendered as a
     <p> for ToC-isolation reasons (see comment above). Visual weight
     mirrors the H2 styling used in essays that have body sections,
     so a reader can't tell from typography alone that this isn't a
     "real" heading — only the ToC knows.

