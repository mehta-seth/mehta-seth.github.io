---
// src/pages/cities/index.astro
//
// Phase 4 — the cities index page (§5/Phase 4 of the v1 plan).
//
// Layout intent (§3.2):
//   - Same wordmark top-left, theme toggle top-right chrome as essay pages.
//   - No H1 — Paul's /photos goes straight into cards, and we follow him.
//   - Vertical stack of three CityCards (not a grid). Paul's page scrolls
//     long on purpose; that's the right feel for a quiet archive.
//
// Deferred to v2 (§9):
//   - Individual /cities/<slug>/ pages. The CityCard hrefs point at hash
//     anchors today (`#kolhapur` etc.) so the home-page links
//     /cities/#kolhapur land correctly on each card. Flipping to real
//     detail routes is a one-line change in CityCard.astro when v2
//     arrives.
//   - The India-map animation per-city.
//   - Any grouping, filtering, or year navigation.

import BaseLayout from '@/layouts/BaseLayout.astro';
import Wordmark from '@/components/Wordmark.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import CityCard from '@/components/CityCard.astro';
import { Picture } from 'astro:assets';
import { cities } from '@/data/cities';
import artistPhoto from '@/assets/cities/artist.jpg';

// Page-level SEO. Phase 5 will layer on OG images + richer meta; for
// Phase 4 the title + description are enough.
const title = 'Cities — Adit Mehta';
const description =
  'Photographs from Kolhapur, Bangalore, and Pune — an archive of the places Adit Mehta has called home, visual notes on monsoons, weekends, and evenings.';
---

<BaseLayout title={title} description={description}>
  <ThemeToggle />

  {/* Page header — mirrors the essay layout's chrome so the wordmark
      and toggle feel consistent across every sub-page. No "Archive"
      link here (that lived on essay pages only); the wordmark alone
      is the route back home. Padding-right reserves space for the
      fixed theme toggle at top:1.25rem right:1.25rem from global.css. */}
  <header class="cities-header">
    <Wordmark href="/" size="small" />
  </header>

  <main class="cities-stage">
    {/* ───────── Header photograph ─────────
        A single page-anchoring image at the top of the cities index.
        Inline <Picture> rather than the <Figure> component because
        Figure's CSS is scoped to .essay__body and this isn't an essay
        — keeping the styling local to this page is cleaner than
        broadening Figure's scope.

        Uses the same widths array and AVIF/WebP/JPEG output chain as
        CityCard. LCP candidate on this page, so loading="eager" +
        decoding="sync". */}
    <figure class="cities-hero">
      <Picture
        src={artistPhoto}
        formats={['avif', 'webp']}
        fallbackFormat="jpg"
        widths={[640, 1024, 1600, 2400, 3000]}
        sizes="(min-width: 50rem) 50rem, 100vw"
        quality={85}
        alt="Photograph by Adit Mehta."
        loading="eager"
        decoding="sync"
        class="cities-hero__img"
      />
    </figure>

    {/* ───────── In-progress notice (§5/Phase 5.7) ─────────
        A single quiet editorial line above the first card, explaining
        that the covers are still placeholders. Deliberately NOT a box,
        banner, alert, icon, or dismissible element — it's a note on the
        page, not a system message. When the real photos ship in v2,
        this one <p> gets deleted in a single edit.

        No role="note", no aria-live — it's static content, plain prose
        read top-to-bottom with the rest of the page. */}
    <p class="cities-notice">
      Photos coming soon. These covers are placeholders.
    </p>

    {/* Stack of cards. With the hero image above now serving as the
        page's LCP candidate (loading="eager"), every card is lazy. */}
    {cities.map((city) => (
      <CityCard
        name={city.name}
        slug={city.slug}
        caption={city.caption}
        image={city.image}
        meta={city.meta}
        alt={city.alt}
        loading="lazy"
      />
    ))}
  </main>
</BaseLayout>

<style>
  /* Page header — same visual language as EssayLayout.astro's
     .essay-header, but without the right-side "Archive" link.
     Max-width matches the stage below so the header and content align
     to the same edge. */
  .cities-header {
    display: flex;
    align-items: baseline;
    padding: 2rem 1.5rem 0;
    padding-right: 4.5rem; /* clear the fixed theme toggle */
    max-width: 56rem;
    margin-inline: auto;
  }

  /* The cards container. Wider than the essay column (42.5rem) because
     photographs want room; narrower than Paul's page (which is ~48rem
     at its widest) to keep the site cohesive. 50rem reads comfortably
     on desktop and full-bleed-ish on mobile. Top padding is generous —
     §3.7 says "Cities page starts from the top, small padding", which
     I'm reading as "no vertical centering, modest top padding" rather
     than "cram it to the edge". */
  .cities-stage {
    max-width: 50rem;
    margin-inline: auto;
    padding: 3rem 1.5rem 8rem;
  }

  @media (min-width: 1024px) {
    .cities-stage {
      padding: 4rem 2rem 10rem;
    }
  }

  /* ── Header photograph (page anchor, above the notice) ──
     Sits at the top of the page, sized to match the cards container
     beneath it (50rem). Bottom margin gives the image room before the
     notice, then the notice has its own margin before the first card.
     The figure wrapper carries margin; the img inside is full-width of
     the figure with auto height so the natural aspect is preserved.
     Slight border-radius to match CityCard's image rendering. */
  .cities-hero {
    margin: 0 0 2.5rem 0;
  }
  .cities-hero__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 2px;
  }

  /* ── In-progress notice (§5/Phase 5.7) ──
     Quiet editorial note. Small type, muted color, italic for voice,
     left-aligned to match the card column. Generous bottom margin so
     it sits in its own air before the first card. Not boxed, not
     framed — it's a line of prose, not a system message. */
  .cities-notice {
    font-size: var(--fs-small);
    color: var(--text-muted);
    font-style: italic;
    margin: 0 0 2rem 0;
    line-height: 1.5;
    max-width: 32rem;
  }
</style>
