---
// Phase 2 home page.
//
// Per §5/Phase 2 and §3.2: the "red rectangle" business-card home. One
// centered column, max ~640px, from top to bottom: wordmark, bio, Essays
// section, Cities section, email line. No nav bar, no footer — the
// wordmark is the entire chrome (§3.2).
//
// Content on this page is deliberately static and authored in-file rather
// than pulled from a content collection. Two reasons:
//   1. Phase 3 owns the essays collection; we must not create it yet.
//   2. The essays-and-cities lists on the home page are curated (2–4
//      items each), not an exhaustive listing — even in v2 they stay
//      hand-picked here, with the full archive living on dedicated pages.
//
// What's deferred (per the plan):
//   - Linking to real essay/city pages that don't exist yet. Phase 3
//     creates /essays/four-shopkeepers/; Phase 4 creates /cities/. The
//     hrefs below point at those future routes — Astro's dev server will
//     404 on them today, which is expected and correct.
//   - The India-map animation on the wordmark (v2 per §9).
//   - An /about page the bio's "More" link might eventually target (v2).

import BaseLayout from '../layouts/BaseLayout.astro';
import Wordmark from '../components/Wordmark.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

// Curated list — data lives inline rather than in a separate module.
// When the second essay is written, drop it in here; when a third comes
// along, consider whether it's time to spin up /essays/ (the archive
// page, deferred to v2 per §7 decision 2).
const essays = [
  {
    title: 'Four Shopkeepers & a Trillion Transactions',
    href: '/essays/four-shopkeepers/',
    // Date is intentionally omitted from v1 display per §3.2: "date/meta
    // optional". Dario's home list is title-only; we follow him.
  },
  // Item 2 per §5/Phase 2: "a placeholder '—' or a greyed-out item".
  // Rendered as a non-link, muted, so it reads as "coming soon" rather
  // than a broken affordance.
  null,
];

// v1: anchors on the cities index page (§5/Phase 2). v2: real routes.
const cities = [
  { name: 'Kolhapur', href: '/cities/#kolhapur' },
  { name: 'Bangalore', href: '/cities/#bangalore' },
  { name: 'Pune', href: '/cities/#pune' },
];

// Primary contact — also referenced in the doc's author line. Kept in a
// const so Phase 5's OG-image generator can reuse it if we want.
const email = 'ad1t.mehta00@gmail.com';
---

<BaseLayout
  title="Adit Mehta · अदित मेहता"
  description="Adit Mehta — student at LSE. Occasional essays on markets and cities; photographs from Kolhapur, Bangalore, and Pune."
>
  <ThemeToggle />

  <main class="home-stage">
    <article class="home-card">
      {/* Wordmark is top-left of the content column, not page chrome
          (§3.2). The component itself is an <a href="/">, so it's a
          self-referencing home link on this page — fine; it's the same
          link pattern used on every other page, and consistency matters. */}
      <header class="home-card__head">
        <Wordmark href="/" />
      </header>

      {/* Bio — §8.1 verbatim. The "More" link is a visual placeholder
          per the plan; in v2 it becomes an /about link or inline
          expansion. Left as href="#" today so hover/focus states still
          demo correctly. */}
      <p class="bio">
        Adit Mehta is a student at the London School of Economics. He writes
        occasionally about markets, cities, and whatever else is keeping him
        up at night. He grew up in Kolhapur, spent his twenties in Bangalore
        and Pune, and is now learning to miss them both from London.{' '}
        <a href="#" class="bio__more">More</a>
      </p>

      {/* Essays. Plain <ul> with list-style removed — semantically a
          list, visually a stack of links. Dario-style: title only, no
          bullet glyphs, generous vertical rhythm. */}
      <section class="home-section" aria-labelledby="h-essays">
        <h2 id="h-essays" class="home-section__heading">Essays</h2>
        <ul class="linklist">
          {essays.map((essay) =>
            essay ? (
              <li class="linklist__item">
                <a href={essay.href}>{essay.title}</a>
              </li>
            ) : (
              <li class="linklist__item linklist__item--placeholder" aria-hidden="true">
                <span>—</span>
              </li>
            ),
          )}
        </ul>
      </section>

      {/* Cities. v1 hrefs are anchors on /cities/ (which Phase 4 builds). */}
      <section class="home-section" aria-labelledby="h-cities">
        <h2 id="h-cities" class="home-section__heading">Cities</h2>
        <ul class="linklist">
          {cities.map((city) => (
            <li class="linklist__item">
              <a href={city.href}>{city.name}</a>
            </li>
          ))}
        </ul>
      </section>

      {/* Email line. Per §3.2: "styled the same as the red handwritten
          email in the sketch (i.e., it *looks* like part of the card,
          not like a footer)." No border-top, no separator — it's just
          a line of italic serif in accent color, sitting at the bottom
          of the card as a signature. Kalam would feel right for the
          "handwritten" vibe, but §3.4 forbids Kalam for Latin — so we
          use Newsreader italic instead, which is our established body
          face and carries warmth without jumping scripts. */}
      <p class="signoff">
        <a href={`mailto:${email}`} class="signoff__email">{email}</a>
      </p>
    </article>
  </main>
</BaseLayout>

<style>
  /* ─── Layout ─────────────────────────────────────────────────────
     Per §3.7: the home card sits centered vertically and horizontally
     on desktop with "breathing room above and below", and on mobile
     has comfortable padding from the edges. This is the same
     `.home-stage` wrapper used in the Phase 1 placeholder, extended. */
  .home-stage {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
  }

  /* Tighter, top-aligned layout on narrow screens — the card is tall
     enough with bio + two lists + email that vertical centering on a
     phone pushes content below the fold. §3.7: "comfortable padding
     (24px) from the edges, not full-bleed." */
  @media (max-width: 640px) {
    .home-stage {
      align-items: flex-start;
      padding: 3rem 1.5rem 2.5rem;
    }
  }

  /* ─── Card internals ─────────────────────────────────────────────
     `.home-card` (width / max-width / margin-inline / base padding) is
     defined in global.css §7 and shared with any future card layout.
     Everything below is page-local rhythm.
     The card body is written in a single vertical flow; we use margin-
     top on each block to build rhythm, rather than row-gap, so adjacent
     elements (e.g., a blockquote inside the bio later) collapse margins
     naturally. */
  .home-card__head {
    margin-bottom: 2rem;
  }

  .bio {
    /* Slightly muted body color echoes Dario's bio paragraph: the
       wordmark is the primary voice, the bio is context. */
    color: var(--text);
    max-width: 36rem;
  }

  /* The inline "More" link — visually subdued so it doesn't steal focus
     from the bio itself. Keeps the accent color on hover. */
  .bio__more {
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-thickness: 0.04em;
    text-underline-offset: 0.2em;
  }
  .bio__more:hover {
    color: var(--accent);
  }

  /* Section headings ("Essays", "Cities") — smaller than an essay H2;
     these sit inline with the body text, not as page-level chapter
     breaks. Rhythm: 2.5rem top margin for section, 0.5rem gap before
     the list. */
  .home-section {
    margin-top: 2.5rem;
  }
  .home-section__heading {
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: 0.5rem;
    /* Slight letter-spacing loosening on small caps feel — kept subtle. */
    letter-spacing: -0.005em;
  }

  /* Vertical list of links — no bullet markers, generous spacing.
     Both the Essays list and the Cities list use this. */
  .linklist {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .linklist__item {
    margin: 0;
    padding: 0.15rem 0;
    line-height: 1.55;
  }
  .linklist__item a {
    /* On list items, the default underlined-on-rest link style feels
       heavy — Dario's lists underline on hover only. Keep that. */
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .linklist__item a:hover,
  .linklist__item a:focus-visible {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  /* The "—" placeholder for the unwritten second essay. Muted, no
     affordance, no hover state. */
  .linklist__item--placeholder {
    color: var(--text-muted);
    user-select: none;
  }

  /* Email line — the business-card signature. §3.2 wants this to read
     as part of the card, not a footer. No top border, no separator.
     Italic Newsreader in accent color, sized small. */
  .signoff {
    margin-top: 3rem;
    margin-bottom: 0;
    font-style: italic;
    font-size: var(--fs-small);
  }
  .signoff__email {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 150ms ease;
  }
  .signoff__email:hover,
  .signoff__email:focus-visible {
    border-bottom-color: var(--accent);
  }
</style>
