---
// Wordmark.astro
// The bilingual name-as-home-link that appears on every page.
// Renders: "Adit Mehta · अदित मेहता" — Latin in Newsreader, Devanagari
// in Kalam, separated by a middle-dot.
//
// Props:
//   href:  where the wordmark links to. Default '/'. Essay pages may pass
//          '/' explicitly; the component doesn't assume anything.
//   size:  'default' | 'small'. Small variant for sub-page headers (essay,
//          cities) per §3.2. Phase 1 only uses 'default' on the home page.

interface Props {
  href?: string;
  size?: 'default' | 'small';
}

const { href = '/', size = 'default' } = Astro.props;

// Use a dynamic class to scale down without duplicating wordmark styles.
const sizeClass = size === 'small' ? 'wordmark--small' : '';
---

<a
  class:list={['wordmark', sizeClass]}
  href={href}
  aria-label="Adit Mehta — home"
>
  <span class="latin">Adit Mehta</span>
  <span class="dot" aria-hidden="true">·</span>
  {/* lang="hi" so screen readers and spellcheck treat this as Hindi
      and the browser picks the right shaper for the glyphs. */}
  <span class="devanagari" lang="hi">अदित मेहता</span>
</a>

<style>
  .wordmark {
    /* Display-size on the home page, where the wordmark IS the page
       header and earns real real estate. */
    font-size: clamp(1.5rem, 1.2rem + 1.2vw, 1.875rem);
  }
  .wordmark--small {
    /* Header-size on essay & index pages. At 18px (original) this sat
       BELOW body size and read as apologetic — the wordmark is the
       brand mark on every page and should anchor, not shrink. 22→24
       puts it comfortably above body (20→22) and clearly below the
       essay title (40→56): its correct role is primary identity, not
       display or decoration. */
    font-size: clamp(1.375rem, 1.25rem + 0.3vw, 1.5rem);
  }
</style>
